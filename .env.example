# ═══════════════════════════════════════════════════════════════
# AgentForge Environment Configuration
# Copy this file to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# LLM Configuration
# ═══════════════════════════════════════════════════════════════

# Ollama (Local LLM - Optional)
# Install: https://ollama.ai/
# Verify: curl http://localhost:11434/api/tags
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:0.5b
USE_OLLAMA=true

# Gemini API (REQUIRED)
# Get free API key: https://ai.google.dev/
# Free tier: 60 requests/minute
GEMINI_API_KEY=your_gemini_api_key_here

# ═══════════════════════════════════════════════════════════════
# ArmorIQ Security (REQUIRED)
# Get API key: https://armoriq.ai/
# ═══════════════════════════════════════════════════════════════
ARMORIQ_API_KEY=your_armoriq_api_key_here
ARMORIQ_SECRET_KEY=your_secure_secret_key_here
ARMORIQ_USER_ID=agentforge-user
ARMORIQ_AGENT_ID=agentforge-agent
ARMORIQ_CONTEXT_ID=default
ARMORIQ_API_ENDPOINT=https://api.armoriq.ai/v1
ARMORIQ_TOKEN_VALIDITY=600

# ═══════════════════════════════════════════════════════════════
# Service URLs
# ═══════════════════════════════════════════════════════════════
BACKEND_URL=http://localhost:8001
SPACETIMEDB_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5174
VITE_BACKEND_URL=http://localhost:8001
VITE_SPACETIMEDB_URL=http://localhost:3001

# ═══════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════
SPACETIMEDB_HOST=spacetimedb
SPACETIMEDB_PORT=3000

# ═══════════════════════════════════════════════════════════════
# Application
# ═══════════════════════════════════════════════════════════════
NODE_ENV=development
DEBUG=true
LOG_LEVEL=INFO
AGENT_TIMEOUT=30
AGENT_MAX_TOKENS=2048
